# VitalCommand 生产环境配置
# 部署前请填写实际值

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# 认证（生产环境建议开启）
HEALTH_AUTH_ENABLED=true

# AI/LLM 配置（用于生成健康建议和报告）
HEALTH_LLM_PROVIDER=anthropic
HEALTH_LLM_MODEL=claude-sonnet-4-20250514
HEALTH_LLM_API_KEY=your-api-key-here

# 数据库路径（容器内或裸机绝对路径）
# HEALTH_DB_PATH=./data/health.sqlite
