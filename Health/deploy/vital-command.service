[Unit]
Description=VitalCommand Health Server
After=network.target

[Service]
Type=simple
User=xmly
WorkingDirectory=/opt/vital-command
EnvironmentFile=-/opt/vital-command/.env
ExecStart=/usr/bin/node server.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOSTNAME=0.0.0.0

[Install]
WantedBy=multi-user.target
